{
  "openapi": "3.0.1",
  "info": {
    "title": "NABH API",
    "version": "v1"
  },
  "paths": {
    "/api/Auth/getToken": {
      "post": {
        "tags": [
          "Auth"
        ],
        "parameters": [
          {
            "name": "ApiKey",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "ApiSecret",
            "in": "query",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/Claims/AddClaim": {
      "post": {
        "tags": [
          "Claims"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AssessmentDataForOtherPortal"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/AssessmentDataForOtherPortal"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/AssessmentDataForOtherPortal"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/Claims/UpdateClaim": {
      "post": {
        "tags": [
          "Claims"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AssessmentDataForOtherPortal"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/AssessmentDataForOtherPortal"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/AssessmentDataForOtherPortal"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/Claims/GetClaimDetail": {
      "get": {
        "tags": [
          "Claims"
        ],
        "parameters": [
          {
            "name": "claimId",
            "in": "query",
            "schema": {
              "type": "integer",
              "format": "int32"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/Claims/GetClaimListByAssessorIdOrPanNumber": {
      "get": {
        "tags": [
          "Claims"
        ],
        "parameters": [
          {
            "name": "AssessorId",
            "in": "query",
            "schema": {
              "type": "integer",
              "format": "int32"
            }
          },
          {
            "name": "PanNo",
            "in": "query",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/EventAndTrainingUser/CreateUser": {
      "post": {
        "tags": [
          "EventAndTrainingUser"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/DtoCreateUserRequest"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/DtoCreateUserRequest"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/DtoCreateUserRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "AssessmentDataForOtherPortal": {
        "required": [
          "address",
          "applicationType",
          "assessmentType",
          "assessorType",
          "fromDate",
          "hcoCity",
          "hcoCountry",
          "hcoName",
          "hcoState",
          "panNumber",
          "programName",
          "refNo",
          "reviewCycles",
          "status",
          "toDate"
        ],
        "type": "object",
        "properties": {
          "claimId": {
            "type": "integer",
            "format": "int32"
          },
          "assignmentID": {
            "type": "integer",
            "format": "int32"
          },
          "refNo": {
            "minLength": 1,
            "type": "string"
          },
          "hcoName": {
            "maxLength": 300,
            "minLength": 1,
            "type": "string"
          },
          "reviewCycles": {
            "type": "integer",
            "format": "int32"
          },
          "programName": {
            "minLength": 1,
            "type": "string"
          },
          "applicationType": {
            "minLength": 1,
            "type": "string"
          },
          "assessmentType": {
            "minLength": 1,
            "type": "string"
          },
          "assessorType": {
            "minLength": 1,
            "type": "string"
          },
          "hcoCountry": {
            "minLength": 1,
            "type": "string"
          },
          "hcoState": {
            "minLength": 1,
            "type": "string"
          },
          "hcoCity": {
            "minLength": 1,
            "type": "string"
          },
          "address": {
            "minLength": 1,
            "type": "string"
          },
          "status": {
            "minLength": 1,
            "pattern": "^(Pending|Completed)$",
            "type": "string"
          },
          "panNumber": {
            "minLength": 1,
            "pattern": "^[A-Z]{5}[0-9]{4}[A-Z]{1}$",
            "type": "string"
          },
          "fromDate": {
            "type": "string",
            "format": "date-time"
          },
          "toDate": {
            "type": "string",
            "format": "date-time"
          }
        },
        "additionalProperties": false
      },
      "DtoCreateUserRequest": {
        "required": [
          "email",
          "firstName",
          "password"
        ],
        "type": "object",
        "properties": {
          "firstName": {
            "minLength": 1,
            "type": "string"
          },
          "lastName": {
            "type": "string",
            "nullable": true
          },
          "email": {
            "minLength": 1,
            "type": "string",
            "format": "email"
          },
          "password": {
            "minLength": 6,
            "type": "string"
          },
          "phone": {
            "maxLength": 15,
            "minLength": 0,
            "type": "string",
            "format": "tel",
            "nullable": true
          },
          "mobile": {
            "pattern": "^[6-9]\\d{9}$",
            "type": "string",
            "nullable": true
          },
          "designation": {
            "type": "string",
            "nullable": true
          },
          "department": {
            "type": "string",
            "nullable": true
          },
          "address": {
            "type": "string",
            "nullable": true
          },
          "city": {
            "type": "string",
            "nullable": true
          },
          "state": {
            "type": "string",
            "nullable": true
          },
          "country": {
            "type": "string",
            "nullable": true
          },
          "organizationName": {
            "type": "string",
            "nullable": true
          },
          "panNumber": {
            "pattern": "^[A-Z]{5}[0-9]{4}[A-Z]{1}$",
            "type": "string",
            "nullable": true
          },
          "tanNumber": {
            "type": "string",
            "nullable": true
          },
          "isGstAvailable": {
            "type": "boolean"
          },
          "gstNumber": {
            "pattern": "^[0-9]{2}[A-Z]{5}[0-9]{4}[A-Z]{1}[A-Z0-9]{3}$",
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      }
    },
    "securitySchemes": {
      "Bearer": {
        "type": "http",
        "description": "Enter JWT Token",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    }
  },
  "security": [
    {
      "Bearer": [ ]
    }
  ]
}